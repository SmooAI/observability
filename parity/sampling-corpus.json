                "spanId": "00f067aa0ba902b7",
                "flags": 1,
                "sampled": true
            }
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-00",
            "expected": {
                "traceId": "4bf92f3577b34da6a3ce929d0e0e4736",
                "spanId": "00f067aa0ba902b7",
                "flags": 0,
                "sampled": false
            }
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-03",
            "expected": {
                "traceId": "4bf92f3577b34da6a3ce929d0e0e4736",
                "spanId": "00f067aa0ba902b7",
                "flags": 3,
                "sampled": true
            }
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-fe",
            "expected": {
                "traceId": "4bf92f3577b34da6a3ce929d0e0e4736",
                "spanId": "00f067aa0ba902b7",
                "flags": 254,
                "sampled": false
            }
        },
        {
            "input": "01-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01",
            "expected": null,
            "why": "wrong version — strict parser accepts only 00"
        },
        {
            "input": "ff-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01",
            "expected": null,
            "why": "version ff is forbidden by the W3C spec"
        },
        {
            "input": "00-00000000000000000000000000000000-00f067aa0ba902b7-01",
            "expected": null,
            "why": "all-zero trace id is invalid"
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-0000000000000000-01",
            "expected": null,
            "why": "all-zero span id is invalid"
        },
        {
            "input": "00-4BF92F3577B34DA6A3CE929D0E0E4736-00f067aa0ba902b7-01",
