            "why": "hex must be lowercase"
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e473-00f067aa0ba902b7-01",
            "expected": null,
            "why": "trace id too short"
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-1",
            "expected": null,
            "why": "flags must be exactly two hex digits"
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7",
            "expected": null,
            "why": "too few fields"
        },
        {
            "input": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01-extra",
